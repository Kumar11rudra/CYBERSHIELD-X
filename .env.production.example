# 🛡️ CyberShield X — PRODUCTION CONFIGURATION
# Copy this to .env on your production server

NODE_ENV=production
PORT=5000

# SECURITY: Use long, random strings (e.g., openssl rand -base64 64)
JWT_SECRET=CHANGE_ME_NOW_FOR_PRODUCTION_SECURITY
JWT_REFRESH_SECRET=CHANGE_ME_NOW_FOR_PRODUCTION_REFRESH_SECURITY

# DATABASE: MongoDB Atlas connection string recommended for production
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/cybershield?retryWrites=true&w=majority

# CLIENT URL: Your production domain
CLIENT_URL=https://cybershieldx.com

# THREAT INTEL APIs
VIRUSTOTAL_API_KEY=your_production_key
ABUSEIPDB_API_KEY=your_production_key

# EMAIL: SMTP configuration for 2FA and Alerts
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=5857
EMAIL_USER=apikey
EMAIL_PASS=your_smtp_password
EMAIL_FROM=security@cybershieldx.com
EMAIL_PREVIEW_MODE=false

# FIREWALL: Allowed IPs for admin access (comma separated)
ADMIN_ALLOWED_IPS=127.0.0.1,your_office_ip

# AI CHATBOT: Groq API key for CyboBot (get from https://console.groq.com)
REACT_APP_GROQ_API_KEY=your_groq_api_key_here
