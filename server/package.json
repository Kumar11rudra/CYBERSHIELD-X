{
  "name": "cybershield-x-server",
  "version": "1.0.0",
  "description": "CyberShield X - Cybersecurity Threat Detection Platform API",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon --legacy-watch --watch . --ext js,mjs,cjs,json,env index.js",
    "seed:admin": "node scripts/seedAdmin.js",
    "test": "NODE_ENV=test jest --detectOpenHandles --forceExit",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:coverage": "NODE_ENV=test jest --coverage --detectOpenHandles --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 10000,
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "middleware/**/*.js",
      "utils/**/*.js",
      "services/**/*.js",
      "!**/node_modules/**"
    ]
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "mongoose-field-encryption": "^7.0.1",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.14.0",
    "qrcode": "^1.5.4",
    "redis": "^5.12.1",
    "socket.io": "^4.7.4",
    "speakeasy": "^2.0.0",
    "ua-parser-js": "^2.0.9",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  }
}
